---
import { Apple } from '@/components/icons/Apple'
import BibleBreathing from '@/components/icons/BibleBreathing'
import Link from '@/components/Link'
import { cn } from '@/lib/utils'
---

<Link
  href='https://apps.apple.com/us/app/sacred-breath-bible-breathing/id6759012826'
  aria-label='Featured work'
  target='_blank'
  class='group relative flex size-full items-center gap-5 rounded-[inherit] px-5'
>
  <div class='absolute inset-0 overflow-hidden rounded-[inherit]'>
    <div
      class:list={[
        'radial-gradient pointer-events-none absolute -right-1/3 -top-1/4 -z-10 size-96 select-none',
        'transition-transform group-hover:-translate-y-4'
      ]}
    >
    </div>
  </div>
  <div
    class='pointer-events-none absolute bottom-0 left-0 right-0 h-[150%] overflow-hidden rounded-[inherit]'
  >
    <BibleBreathing
      width={72}
      height={72}
      className={cn(
        'absolute -bottom-2 right-8 rotate-12 rounded-2xl',
        'custom-icon-transition transition-transform duration-600',
        'group-hover:-translate-x-4 group-hover:-translate-y-12 group-hover:-rotate-12'
      )}
    />
  </div>
  <Apple className='size-10' />
  <div>
    <p class='text-sm !font-light leading-tight opacity-80'>Available on the</p>
    <p class='text-2xl leading-tight'>App Store</p>
  </div>
</Link>

<style>
  .radial-gradient {
    background: radial-gradient(
      closest-side,
      #366d39 0%,
      rgba(0, 0, 0, 0) 100%
    );
  }

  .custom-icon-transition {
    transition-timing-function: cubic-bezier(0.19, 1, 0.22, 1);
  }
</style>
